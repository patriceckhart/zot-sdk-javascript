{
  "name": "@patriceckhart/zot-sdk-javascript",
  "version": "0.1.0",
  "description": "TypeScript SDK for embedding zot RPC in Node.js applications.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "zot": "./bin/zot"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "install:zot": "node ./scripts/install-zot.js",
    "postinstall": "node ./scripts/install-zot.js"
  },
  "keywords": [
    "zot",
    "rpc",
    "sdk",
    "ai",
    "agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patriceckhart/zot-sdk-javascript.git"
  },
  "bugs": {
    "url": "https://github.com/patriceckhart/zot-sdk-javascript/issues"
  },
  "homepage": "https://github.com/patriceckhart/zot-sdk-javascript#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
